# Copy to .env and fill in real values. Never commit .env.
# (.opencode/mcp.json and .env are gitignored.)

# ---- Linear MCP (RENT-0) ----
LINEAR_API_KEY=your-linear-personal-api-key-here

# ---- Operator (RENT-0) ----
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=change-me
# OR set OPERATOR_PASSWORD_HASH (bcrypt) instead of OPERATOR_PASSWORD

# ---- Backend (RENT-0) ----
DATABASE_URL=postgresql+psycopg2://ledger:ledger@localhost:5432/ledger
JWT_SECRET=generate-a-long-random-secret
CURRENCY=EGP
